# Copy this to .env and fill in your Firebase project values
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef1234567890

# Admin login — create this account in Firebase console → Authentication → Add user
VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_ADMIN_PASSWORD=your_strong_password_here

# Your public join URL (used for QR code)
# In development: http://localhost:5173
# In production: https://your-app.vercel.app
VITE_JOIN_URL=http://localhost:5173
