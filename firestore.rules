rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────
    function game() {
      return get(/databases/$(database)/documents/meta/gameState).data;
    }
    function question(qId) {
      return get(/databases/$(database)/documents/questions/$(qId)).data;
    }
    function answerKey(qId) {
      return get(/databases/$(database)/documents/answerKeys/$(qId)).data;
    }
    // Mirrors calcScore() in src/firebase/db.js. Firestore rules expose
    // math.round/abs/floor/ceil/pow/sqrt but NOT math.max or math.min —
    // using them makes every rule evaluation error out and deny. Cap via
    // ternary; drop the lower max(5,…) because elapsed is clamped to timer
    // so the expression bottoms out at 30 - 25 = 5 naturally.
    function maxScoreFor(elapsed, timer) {
      return math.round(30 - (elapsed < timer ? elapsed : timer) / timer * 25);
    }

    // Validates an answer write against authoritative server state:
    //   - phase must be 'question'
    //   - answer must be a valid option index (0..3)
    //   - isCorrect must match the actual correctAnswer (read from answerKeys)
    //   - score must be 0 for wrong; 5..maxScoreFor(timeTaken, timer) for correct
    //
    // No client-vs-server-clock check. A malicious client can always claim
    // timeTaken=0 and get the max score for one question (30 pts), so the
    // check added friction without preventing the attack. Every legit
    // submit is now accepted regardless of phone clock drift or cell
    // latency, matching Kahoot/Slido's behavior. Multi-write inflation is
    // still blocked by the 30-pt delta cap on /players updates.
    function answerIsValid(answerId, d) {
      return d.questionId is string
          && d.playerId is string
          // Doc ID must be {questionId}_{playerId}. Stops an attacker from
          // writing arbitrary answer IDs, or writing an answer whose
          // `playerId` field disagrees with the doc's own player — the
          // player-score update in the same tx always targets `d.playerId`,
          // so pinning the ID here pins who can be affected.
          && answerId == d.questionId + '_' + d.playerId
          && d.answer is int
          && d.answer >= 0 && d.answer <= 3
          && d.timeTaken is number
          && d.timeTaken >= 0
          && d.score is int
          && d.score >= 0
          && d.score <= 30
          && d.isCorrect is bool
          && game().phase == 'question'
          && d.isCorrect == (d.answer == answerKey(d.questionId).correctAnswer)
          && (
               (d.isCorrect == false && d.score == 0)
               ||
               (d.isCorrect == true
                 && d.score >= 5
                 && d.score <= maxScoreFor(d.timeTaken, question(d.questionId).timer))
             );
    }

    // ─── meta/gameState ───────────────────────────────────────
    // Public read. One-time bootstrap is locked to initial values so an
    // attacker who deletes the doc can't recreate it with malicious state.
    // After bootstrap, only authenticated admin can update.
    match /meta/{doc} {
      allow read:   if true;
      allow create: if request.resource.data.phase == 'waiting'
                    && request.resource.data.currentQuestionIndex == 0
                    && request.resource.data.questionStartTime == null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // ─── questions ────────────────────────────────────────────
    // Public read; admin-only write. Question docs MUST NOT contain a
    // `correctAnswer` field — it lives in /answerKeys/{id} so players
    // cannot fetch all answers via DevTools before answering.
    match /questions/{id} {
      allow read:   if true;
      // correctAnswer is only a meaningful field on create/update — on
      // delete, request.resource is null and the `in` check errors out,
      // which rejected legit admin deletes. Split delete into its own rule.
      allow create, update: if request.auth != null
                            && !('correctAnswer' in request.resource.data);
      allow delete: if request.auth != null;
    }

    // ─── answerKeys ───────────────────────────────────────────
    // Holds {correctAnswer} per question, separate from the public question
    // doc. Admin can always read/write. Public can read ONLY after the
    // question phase ends, and only for questions at-or-before the current
    // index — i.e., revealed answers are visible, future answers are not.
    match /answerKeys/{id} {
      allow read:  if request.auth != null
                   || game().phase == 'ended'
                   || (
                        (game().phase == 'results' || game().phase == 'leaderboard')
                        && question(id).order <= game().currentQuestionIndex
                      );
      allow write: if request.auth != null;
    }

    // ─── players ──────────────────────────────────────────────
    // Anyone can join (create) with a 2-20 char name and score=0.
    // Updates restricted to ONLY the `score` field, integer 0-5000, AND
    // the per-write delta is capped at 30 (= max single-question score).
    // This means a malicious client can still inflate, but only +30 per
    // write — visible on the live leaderboard, killing drive-by cheating.
    match /players/{playerId} {
      allow read:   if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() >= 2
                    && request.resource.data.name.size() <= 20
                    && request.resource.data.score == 0;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score'])
                    && request.resource.data.score is int
                    && request.resource.data.score >= 0
                    && request.resource.data.score <= 5000
                    && math.abs(request.resource.data.score - resource.data.score) <= 30;
      allow delete: if request.auth != null;
    }

    // ─── answers ──────────────────────────────────────────────
    // Server-validated (see answerIsValid). Cheating attempts:
    //   - score=99999          → rejected (cap 30 + maxScoreFor cap)
    //   - isCorrect=true lie   → rejected (must match actual correctAnswer)
    //   - submit after timer   → rejected (phase != 'question')
    //   - submit before quiz   → rejected (phase != 'question')
    //   - answer index 99      → rejected (must be 0..3)
    //   - write under forged ID → rejected (doc ID must be qId_pId)
    match /answers/{answerId} {
      allow read:   if true;
      allow create: if answerIsValid(answerId, request.resource.data);
      allow update: if answerIsValid(answerId, request.resource.data);
      allow delete: if request.auth != null;
    }

    // ─── sessions ─────────────────────────────────────────────
    // Public read for history; admin-only write (saved when quiz ends).
    match /sessions/{sessionId} {
      allow read:  if true;
      allow write: if request.auth != null;
    }
  }
}
